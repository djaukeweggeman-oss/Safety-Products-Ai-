{
    "version": 2,
    "builds": [
        {
            "src": "server/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/chat",
            "destination": "server/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "public/$1"
        }
    ]
}